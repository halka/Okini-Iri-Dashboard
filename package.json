{
  "name": "bookmark-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "wrangler dev --config dist/server/wrangler.json --persist-to .wrangler/state",
    "deploy": "node scripts/deploy.mjs",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "cf-typegen": "wrangler types",
    "rebuild:local": "node scripts/rebuild-local.mjs",
    "db:migrate:local": "wrangler d1 migrations apply bookmark-dashboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply bookmark-dashboard --remote"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/ts-plugin": "^1.10.10",
    "astro": "^7.1.1",
    "encoding-japanese": "^2.2.0",
    "highlight.js": "^11.11.1",
    "oauth4webapi": "^3.8.6",
    "typescript": "^5.8.3",
    "wrangler": "^4.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "sharp": "^0.35.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.35.3": true,
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true
  }
}
