---
import type { defaultLocale, messages } from "../i18n/messages";
import type { AuthUser } from "../domain/auth";

type Copy = (typeof messages)[typeof defaultLocale];

interface Props {
  t: Copy;
  user: AuthUser;
}

const { t, user } = Astro.props;
const authenticationDisabled = user.issuer === "urn:optional-authentication";
const identity = authenticationDisabled ? t.authenticationDisabled : user.email ? `${user.name} · ${user.email}` : user.name;
---

<dialog id="manager" aria-labelledby="managerTitle">
  <section class="manager-panel">
    <header>
      <h3 id="managerTitle" data-i18n="manageData">{t.manageData}</h3>
      <button type="button" id="closeManager" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>

    <section class="manager-section account-panel">
      <div>
        <h4 data-i18n="account">{t.account}</h4>
        <p><span data-i18n="signedInAs">{t.signedInAs}</span> <strong>{identity}</strong></p>
        {user.local && <small data-i18n="localDevelopmentSession">{t.localDevelopmentSession}</small>}
      </div>
      {
        !authenticationDisabled && (
          <form method="post" action="/auth/logout">
            <button type="submit" class="account-logout" data-i18n="signOut">{t.signOut}</button>
          </form>
        )
      }
    </section>

    <nav class="menu-list" aria-label={t.manageData}>
      <button type="button" id="openFolderManager" class="menu-action" data-i18n="folderManagement">{t.folderManagement}</button>
      <button type="button" id="openTagManager" class="menu-action" data-i18n="tagManagement">{t.tagManagement}</button>
      <button type="button" id="openImportManager" class="menu-action" data-i18n="import">{t.import}</button>
      <button type="button" id="openSystemSettings" class="menu-action" data-i18n="systemSettings">{t.systemSettings}</button>
    </nav>
  </section>
</dialog>

<dialog id="folderManager" aria-labelledby="folderManagerTitle">
  <section class="manager-panel">
    <header>
      <h3 id="folderManagerTitle" data-i18n="folderManagement">{t.folderManagement}</h3>
      <button type="button" id="closeFolderManager" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>

    <section class="manager-section">
      <h4 data-i18n="folders">{t.folders}</h4>
      <p data-i18n="emptyFoldersOnly">{t.emptyFoldersOnly}</p>
      <form id="folderForm" class="compact-form">
        <input name="name" type="text" aria-label={t.newFolderPlaceholder} maxlength="200" placeholder={t.newFolderPlaceholder} required data-i18n-placeholder="newFolderPlaceholder" data-i18n-aria-label="newFolderPlaceholder" />
        <button type="submit" title={t.addFolderTitle} data-i18n="add" data-i18n-title="addFolderTitle">{t.add}</button>
      </form>
      <div id="folderManageList" class="manage-list"></div>
    </section>
  </section>
</dialog>

<dialog id="tagManager" aria-labelledby="tagManagerTitle">
  <section class="manager-panel">
    <header>
      <h3 id="tagManagerTitle" data-i18n="tagManagement">{t.tagManagement}</h3>
      <button type="button" id="closeTagManager" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>

    <section class="manager-section">
      <h4 data-i18n="tags">{t.tags}</h4>
      <p data-i18n="tagManageHint">{t.tagManageHint}</p>
      <form id="tagForm" class="compact-form">
        <input name="name" type="text" aria-label={t.tagNamePlaceholder} maxlength="100" placeholder={t.tagNamePlaceholder} required data-i18n-placeholder="tagNamePlaceholder" data-i18n-aria-label="tagNamePlaceholder" />
        <input name="primaryColor" type="color" value="#4f8cff" aria-label={t.tagColor} data-i18n-aria-label="tagColor" />
        <button type="submit" title={t.addTagTitle} data-i18n="add" data-i18n-title="addTagTitle">{t.add}</button>
      </form>
      <div id="tagManageList" class="manage-list"></div>
    </section>
  </section>
</dialog>

<dialog id="importManager" aria-labelledby="importManagerTitle">
  <section class="manager-panel">
    <header>
      <h3 id="importManagerTitle" data-i18n="import">{t.import}</h3>
      <button type="button" id="closeImportManager" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>

    <section class="import-panel settings-block">
      <div>
        <h4 data-i18n="importBookmarks">{t.importBookmarks}</h4>
        <p data-i18n="importBookmarksHint">{t.importBookmarksHint}</p>
      </div>
      <label class="file-button">
        <span data-i18n="chooseBookmarkHtml">{t.chooseBookmarkHtml}</span>
        <input id="bookmarkHtmlInput" type="file" accept=".html,.htm,text/html" />
      </label>
    </section>
  </section>
</dialog>

<dialog id="systemSettings" aria-labelledby="systemSettingsTitle">
  <section class="manager-panel">
    <header>
      <h3 id="systemSettingsTitle" data-i18n="systemSettings">{t.systemSettings}</h3>
      <button type="button" id="closeSystemSettings" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>

    <section class="settings-block">
      <div class="manager-heading">
        <h4 data-i18n="siteSettings">{t.siteSettings}</h4>
        <p data-i18n="siteSettingsHint">{t.siteSettingsHint}</p>
      </div>
      <form id="siteSettingsForm" class="settings-form">
        <label>
          <span data-i18n="settingTitle">{t.settingTitle}</span>
          <input name="title" type="text" maxlength="120" autocomplete="off" />
        </label>
        <label>
          <span data-i18n="settingSiteName">{t.settingSiteName}</span>
          <input name="siteName" type="text" maxlength="120" autocomplete="off" />
        </label>
        <label class="wide">
          <span data-i18n="settingDescription">{t.settingDescription}</span>
          <textarea name="description" rows="3" maxlength="300"></textarea>
        </label>
        <label class="wide">
          <span data-i18n="settingSiteUrl">{t.settingSiteUrl}</span>
          <input name="url" type="url" inputmode="url" autocomplete="url" maxlength="2000" />
        </label>
        <label class="wide">
          <span data-i18n="settingOgImage">{t.settingOgImage}</span>
          <input name="ogImage" type="text" maxlength="2000" autocomplete="off" />
        </label>
        <label>
          <span data-i18n="settingLocale">{t.settingLocale}</span>
          <input name="locale" type="text" maxlength="20" autocomplete="off" />
        </label>
        <label>
          <span data-i18n="settingAlternateLocale">{t.settingAlternateLocale}</span>
          <input name="alternateLocale" type="text" maxlength="20" autocomplete="off" />
        </label>
        <label>
          <span data-i18n="settingTwitterCard">{t.settingTwitterCard}</span>
          <select name="twitterCard">
            <option value="summary">summary</option>
            <option value="summary_large_image">summary_large_image</option>
          </select>
        </label>
        <footer class="settings-actions">
          <p id="siteSettingsStatus" role="status" aria-live="polite"></p>
          <button type="submit" class="primary" data-i18n="saveSiteSettings">{t.saveSiteSettings}</button>
        </footer>
      </form>
    </section>

    <section class="settings-block">
      <div class="manager-heading">
        <h4 data-i18n="oidcSettings">{t.oidcSettings}</h4>
        <p data-i18n="oidcSettingsHint">{t.oidcSettingsHint}</p>
      </div>
      <form id="oidcSettingsForm" class="settings-form">
        <label class="wide">
          <span data-i18n="settingIssuerUrl">{t.settingIssuerUrl}</span>
          <input name="issuerUrl" type="url" inputmode="url" autocomplete="url" maxlength="2000" />
        </label>
        <label class="wide">
          <span data-i18n="settingClientId">{t.settingClientId}</span>
          <input name="clientId" type="text" maxlength="500" autocomplete="off" />
        </label>
        <label>
          <span data-i18n="settingTokenAuthMethod">{t.settingTokenAuthMethod}</span>
          <select name="tokenAuthMethod">
            <option value="" data-i18n="settingAuto">{t.settingAuto}</option>
            <option value="client_secret_basic">client_secret_basic</option>
            <option value="client_secret_post">client_secret_post</option>
            <option value="none">none</option>
          </select>
        </label>
        <label>
          <span data-i18n="settingSessionTtl">{t.settingSessionTtl}</span>
          <input name="sessionTtlSeconds" type="number" min="300" max="2592000" step="60" inputmode="numeric" />
        </label>
        <label class="wide">
          <span data-i18n="settingScopes">{t.settingScopes}</span>
          <input name="scopes" type="text" maxlength="500" autocomplete="off" />
        </label>
        <label class="wide">
          <span data-i18n="settingAllowedEmails">{t.settingAllowedEmails}</span>
          <textarea name="allowedEmails" rows="2" maxlength="2000"></textarea>
        </label>
        <label class="wide">
          <span data-i18n="settingAllowedDomains">{t.settingAllowedDomains}</span>
          <textarea name="allowedDomains" rows="2" maxlength="2000"></textarea>
        </label>
        <p id="oidcSecretStatus" class="settings-note"></p>
        <footer class="settings-actions">
          <p id="oidcSettingsStatus" role="status" aria-live="polite"></p>
          <button type="submit" class="primary" data-i18n="saveOidcSettings">{t.saveOidcSettings}</button>
        </footer>
      </form>
    </section>

    <section class="reset-panel settings-block">
      <div>
        <h4 data-i18n="resetData">{t.resetData}</h4>
        <p data-i18n="resetDataHint">{t.resetDataHint}</p>
      </div>
      <button id="resetDataButton" type="button" class="danger" data-i18n="resetDataButton">{t.resetDataButton}</button>
    </section>
  </section>
</dialog>
