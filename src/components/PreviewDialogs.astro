---
import type { defaultLocale, messages } from "../i18n/messages";

type Copy = (typeof messages)[typeof defaultLocale];

interface Props {
  t: Copy;
}

const { t } = Astro.props;
---

<dialog id="structuredPreview" aria-labelledby="previewTitle" aria-describedby="previewStatus">
  <section class="preview-panel">
    <header>
      <div>
        <h3 id="previewTitle" data-i18n="structuredPreview">{t.structuredPreview}</h3>
        <p id="previewStatus" role="status" aria-live="polite" data-i18n="previewIdle">{t.previewIdle}</p>
      </div>
      <button type="button" id="closePreview" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>
    <pre id="previewContent"></pre>
  </section>
</dialog>

<dialog id="bookmarkDetailsDialog" aria-labelledby="bookmarkDetailsTitle">
  <section class="link-choice-panel bookmark-details-panel">
    <header>
      <h3 id="bookmarkDetailsTitle" data-i18n="bookmarkDetails">{t.bookmarkDetails}</h3>
      <button type="button" id="closeBookmarkDetails" aria-label={t.close} data-i18n-aria-label="close">×</button>
    </header>
    <dl>
      <div>
        <dt data-i18n="url">{t.url}</dt>
        <dd><a id="bookmarkDetailsUrl" href="#" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer"></a></dd>
      </div>
      <div>
        <dt data-i18n="description">{t.description}</dt>
        <dd id="bookmarkDetailsDescription"></dd>
      </div>
      <div>
        <dt data-i18n="notes">{t.notes}</dt>
        <dd id="bookmarkDetailsNotes"></dd>
      </div>
    </dl>
  </section>
</dialog>

<dialog id="previewLinkDialog" aria-labelledby="previewLinkDialogTitle" aria-describedby="previewLinkUrl">
  <section class="link-choice-panel">
    <h3 id="previewLinkDialogTitle" data-i18n="previewLinkActionTitle">{t.previewLinkActionTitle}</h3>
    <p id="previewLinkUrl"></p>
    <div class="link-choice-actions">
      <button id="openPreviewLinkExternal" type="button" class="primary" data-i18n="openInNewTab">{t.openInNewTab}</button>
      <button id="openPreviewLinkInline" type="button" data-i18n="openInPreview">{t.openInPreview}</button>
      <button id="cancelPreviewLink" type="button" data-i18n="cancel">{t.cancel}</button>
    </div>
  </section>
</dialog>
