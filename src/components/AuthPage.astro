---
import type { Preferences } from "../config/preferences";
import type { defaultLocale, messages } from "../i18n/messages";
import AppHead from "./AppHead.astro";
import "../styles/global.css";

type Copy = (typeof messages)[typeof defaultLocale];

interface Props {
  t: Copy;
  preferences: Preferences;
  title: string;
  description: string;
  actionHref: string;
  actionLabel: string;
}

const { t, preferences, title, description, actionHref, actionLabel } = Astro.props;
---

<!doctype html>
<html
  lang={preferences.locale}
  data-locale={preferences.locale}
  data-theme-preference={preferences.colorMode}
  data-color-mode={preferences.colorMode === "dark" ? "dark" : "light"}
>
  <AppHead t={t} preferences={preferences} />
  <body class="auth-body">
    <main class="auth-screen">
      <section class="auth-panel">
        <img src="/favicon.svg" alt="" width="48" height="48" aria-hidden="true" />
        <h1>{title}</h1>
        <p>{description}</p>
        <a class="primary auth-action" href={actionHref}>{actionLabel}</a>
      </section>
    </main>
  </body>
</html>
