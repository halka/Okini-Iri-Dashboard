---
import type { Preferences } from "../config/preferences";
import type { defaultLocale, messages } from "../i18n/messages";
import { getKv } from "../lib/kv";
import { absoluteSiteUrl, readAppSettings } from "../lib/settings";
import { defaultAppSettings } from "../config/settings";

type Copy = (typeof messages)[typeof defaultLocale];

interface Props {
  t: Copy;
  preferences: Preferences;
}

const { t, preferences } = Astro.props;
const settings = await readAppSettings(getKv(Astro.locals)).catch(() => defaultAppSettings);
const site = settings.site;
const siteUrl = absoluteSiteUrl(site.url);
const ogImageUrl = new URL(site.ogImage, siteUrl).href;
const lightThemeMedia = preferences.colorMode === "system" ? "(prefers-color-scheme: light)" : preferences.colorMode === "light" ? "all" : "not all";
const darkThemeMedia = preferences.colorMode === "system" ? "(prefers-color-scheme: dark)" : preferences.colorMode === "dark" ? "all" : "not all";
const initialColorScheme = preferences.colorMode === "system" ? "light dark" : preferences.colorMode;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="color-scheme" content={initialColorScheme} />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="theme-color" content="#fafafa" media={lightThemeMedia} data-theme-color="light" />
  <meta name="theme-color" content="#323232" media={darkThemeMedia} data-theme-color="dark" />
  <meta name="description" content={site.description || t.metaDescription} />
  <meta property="og:title" content={site.title} />
  <meta property="og:description" content={site.description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:site_name" content={site.siteName} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:locale" content={site.locale} />
  <meta property="og:locale:alternate" content={site.alternateLocale} />
  <meta name="twitter:card" content={site.twitterCard} />
  <meta name="twitter:title" content={site.title} />
  <meta name="twitter:description" content={site.description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <title>{site.title || t.appTitle}</title>
  <link rel="canonical" href={siteUrl} />
  <link rel="icon" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <script is:inline src="/theme-boot.js"></script>
</head>
